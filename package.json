{
  "name": "@odeal/sdk",
  "version": "2.2.14",
  "description": "Odeal Entegrasyon SDK (Otomatik Üretildi)",
  "author": "Odeal",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "build:watch": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "odeal",
    "sdk",
    "payment",
    "api",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/odeal/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.10.0",
    "tsup": "^8.4.0"
  }
}
